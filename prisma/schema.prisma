generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// 01-01: User, Profile, EmailVerification
// ──────────────────────────────────────────────

enum UserStatus {
  unverified
  verified
  onboarded
  suspended
}

enum UserRole {
  user
  admin
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  status       UserStatus @default(unverified)
  role         UserRole   @default(user)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  profile            Profile?
  emailVerifications EmailVerification[]
  projects           Project[]
  uploadedFiles      ProjectFile[]
  projectVersions    ProjectVersion[]
  memberships        ProjectMember[]
  sentInvitations    Invitation[]        @relation("InviterInvitations")
  receivedInvitations Invitation[]       @relation("InviteeInvitations")
  commentThreads     CommentThread[]
  comments           Comment[]
  activityLogs       ActivityLog[]
  splitRecords       SplitRecord[]
  splitContributions SplitContributor[]
  subscription       Subscription?
  adminActions       AdminAction[]
  notifications      Notification[]
  passwordResets     PasswordReset[]
  accountRequests    AccountRequest[]
  gigs               Gig[]
  gigApplications    GigApplication[]
  hiresAsBuyer       Hire[]              @relation("HireBuyer")
  hiresAsTalent      Hire[]              @relation("HireTalent")
  connectAccount     ConnectAccount?
  paymentsAsBuyer    PaymentRecord[]     @relation("PaymentBuyer")
  paymentsAsTalent   PaymentRecord[]     @relation("PaymentTalent")
  payoutsAsTalent    PayoutRecord[]      @relation("PayoutTalent")
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String?
  headline    String?
  bio         String?
  avatarUrl   String?
  skills      String[]
  genres      String[]
  priceRange  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolioSamples PortfolioSample[]
}

// ──────────────────────────────────────────────
// 10-02: PortfolioSample
// ──────────────────────────────────────────────

model PortfolioSample {
  id        String   @id @default(cuid())
  profileId String
  title     String
  url       String
  mimeType  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, sortOrder])
}

model EmailVerification {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ──────────────────────────────────────────────
// 01-07: PasswordReset
// ──────────────────────────────────────────────

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ──────────────────────────────────────────────
// 01-08: AccountRequest (GDPR delete/export)
// ──────────────────────────────────────────────

enum AccountRequestType {
  delete
  export
}

enum AccountRequestStatus {
  pending_verification
  pending
  processing
  completed
  cancelled
}

model AccountRequest {
  id                   String               @id @default(cuid())
  userId               String
  type                 AccountRequestType
  status               AccountRequestStatus @default(pending)
  verifyToken          String?              @unique
  verifyTokenExpiresAt DateTime?
  verifiedAt           DateTime?
  scheduledFor         DateTime?
  exportPayload        Json?
  completedAt          DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, status])
  @@index([scheduledFor])
}

// ──────────────────────────────────────────────
// 02-01: Project
// ──────────────────────────────────────────────

enum ProjectStatus {
  active
  archived
  suspended
  deleted_soft
}

model Project {
  id            String        @id @default(cuid())
  ownerId       String
  title         String
  description   String?
  genre         String?
  tags          String[]
  coverImageUrl String?
  status        ProjectStatus @default(active)
  deletedAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  owner          User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  files          ProjectFile[]
  versions       ProjectVersion[]
  members        ProjectMember[]
  invitations    Invitation[]
  commentThreads CommentThread[]
  activityLogs   ActivityLog[]
  splitRecords   SplitRecord[]
  gigs           Gig[]

  @@index([ownerId])
  @@index([status])
}

// ──────────────────────────────────────────────
// 03-01: ProjectFile
// ──────────────────────────────────────────────

enum FileStatus {
  uploading
  ready
  failed
  deleted_soft
}

model ProjectFile {
  id           String     @id @default(cuid())
  projectId    String
  uploaderId   String
  filename     String
  originalName String
  mimeType     String
  fileSize     Int
  s3Key        String
  s3Bucket     String
  status       FileStatus @default(uploading)
  deletedAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploader User          @relation(fields: [uploaderId], references: [id])
  versions VersionFile[]

  @@index([projectId])
  @@index([status])
}

// ──────────────────────────────────────────────
// 04-01: ProjectVersion + VersionFile
// ──────────────────────────────────────────────

enum VersionStatus {
  draft
  published
  superseded
  deleted_soft
}

model ProjectVersion {
  id          String        @id @default(cuid())
  projectId   String
  authorId    String
  name        String
  changelog   String?
  status      VersionStatus @default(draft)
  publishedAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User          @relation(fields: [authorId], references: [id])
  files   VersionFile[]

  @@index([projectId])
  @@index([status])
}

model VersionFile {
  versionId String
  fileId    String

  version ProjectVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  file    ProjectFile    @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@id([versionId, fileId])
}

// ──────────────────────────────────────────────
// 05-01: ProjectMember, Invitation
// ──────────────────────────────────────────────

enum MemberRole {
  owner
  editor
  commenter
  viewer
}

enum InvitationStatus {
  pending
  accepted
  revoked
  expired
}

model ProjectMember {
  id        String     @id @default(cuid())
  projectId String
  userId    String
  role      MemberRole @default(viewer)
  joinedAt  DateTime   @default(now())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model Invitation {
  id           String           @id @default(cuid())
  projectId    String
  inviterId    String
  inviteeEmail String
  inviteeUserId String?
  role         MemberRole       @default(viewer)
  status       InvitationStatus @default(pending)
  token        String           @unique
  expiresAt    DateTime
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inviter User    @relation("InviterInvitations", fields: [inviterId], references: [id])
  invitee User?   @relation("InviteeInvitations", fields: [inviteeUserId], references: [id])

  @@index([projectId])
  @@index([inviteeEmail])
  @@index([token])
  @@index([status])
}

// ──────────────────────────────────────────────
// 06-01: CommentThread, Comment, ActivityLog
// ──────────────────────────────────────────────

enum ThreadStatus {
  open
  resolved
  deleted_soft
}

enum TargetType {
  project
  file
  version
}

enum ActivityAction {
  file_uploaded
  file_deleted
  version_published
  version_deleted
  member_joined
  comment_added
  split_submitted
  split_confirmed
  split_rejected
  member_invited
  member_removed
  project_created
  project_archived
  project_restored
  project_deleted
  gig_created
  gig_published
  gig_closed
  gig_cancelled
  gig_application_submitted
  gig_application_withdrawn
  gig_application_accepted
  gig_application_rejected
  gig_hire_started
  gig_hire_delivered
  gig_hire_approved
  gig_hire_cancelled
  gig_hire_access_granted
  hire_payment_succeeded
  hire_payment_failed
  hire_payout_scheduled
  hire_payout_paid
  hire_payout_held
  hire_payout_released
  hire_payout_failed
  connect_onboarding_started
  connect_onboarding_completed
}

model CommentThread {
  id         String       @id @default(cuid())
  projectId  String
  targetType TargetType
  targetId   String
  authorId   String
  status     ThreadStatus @default(open)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author   User      @relation(fields: [authorId], references: [id])
  comments Comment[]

  @@index([projectId, targetType, targetId])
}

model Comment {
  id        String    @id @default(cuid())
  threadId  String
  authorId  String
  body      String
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  thread CommentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User          @relation(fields: [authorId], references: [id])

  @@index([threadId])
}

model ActivityLog {
  id         String         @id @default(cuid())
  projectId  String
  actorId    String
  action     ActivityAction
  targetType String
  targetId   String
  metadata   Json?
  createdAt  DateTime       @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actor   User    @relation(fields: [actorId], references: [id])

  @@index([projectId, targetType, targetId])
}

// ──────────────────────────────────────────────
// 06-07: Notification
// ──────────────────────────────────────────────

enum NotificationType {
  comment_added
  invitation_received
  version_published
  member_joined
  split_submitted
  split_confirmed
  split_rejected
  trial_ending_soon
  trial_expired
  gig_application_received
  gig_application_accepted
  gig_application_rejected
  gig_hire_started
  gig_hire_delivered
  gig_hire_approved
  gig_hire_cancelled
  gig_hire_access_granted
  hire_payment_succeeded
  hire_payment_failed
  hire_payout_scheduled
  hire_payout_paid
  hire_payout_held
  hire_payout_released
  hire_payout_failed
  connect_kyc_required
  connect_verified
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  type       NotificationType
  title      String
  body       String?
  isRead     Boolean          @default(false)
  sourceType String?
  sourceId   String?
  createdAt  DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
}

// ──────────────────────────────────────────────
// 07-01: SplitRecord, SplitContributor, SplitConfirmation
// ──────────────────────────────────────────────

enum SplitStatus {
  draft
  pending_confirmation
  partially_confirmed
  confirmed
  rejected
  superseded
}

enum ConfirmationStatus {
  pending
  confirmed
  rejected
  expired
}

model SplitRecord {
  id             String      @id @default(cuid())
  projectId      String
  createdById    String
  status         SplitStatus @default(draft)
  supersededById String?     @unique
  submittedAt    DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  project      Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy    User               @relation(fields: [createdById], references: [id])
  supersededBy SplitRecord?       @relation("SplitSupersedes", fields: [supersededById], references: [id])
  supersedes   SplitRecord?       @relation("SplitSupersedes")
  contributors SplitContributor[]

  @@index([projectId])
}

model SplitContributor {
  id            String   @id @default(cuid())
  splitRecordId String
  userId        String
  role          String
  percentage    Decimal  @db.Decimal(5, 2)
  createdAt     DateTime @default(now())

  splitRecord  SplitRecord        @relation(fields: [splitRecordId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id])
  confirmation SplitConfirmation?

  @@unique([splitRecordId, userId])
}

model SplitConfirmation {
  id                 String             @id @default(cuid())
  splitContributorId String             @unique
  status             ConfirmationStatus @default(pending)
  respondedAt        DateTime?
  createdAt          DateTime           @default(now())

  splitContributor SplitContributor @relation(fields: [splitContributorId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────
// 08-01: Subscription, PaymentEvent
// ──────────────────────────────────────────────

enum SubscriptionPlan {
  trial
  pro
  team
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  expired
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  plan                   SubscriptionPlan   @default(trial)
  status                 SubscriptionStatus @default(trialing)
  trialEndsAt            DateTime?
  currentPeriodEnd       DateTime?
  canceledAt             DateTime?
  trialEndingNotifiedAt  DateTime?
  trialExpiredNotifiedAt DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  events PaymentEvent[]

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([status])
  @@index([status, trialEndsAt])
}

model PaymentEvent {
  id             String    @id @default(cuid())
  subscriptionId String?
  paymentId      String?
  stripeEventId  String    @unique
  type           String
  payload        Json
  processedAt    DateTime?
  createdAt      DateTime  @default(now())

  subscription Subscription?  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  payment      PaymentRecord? @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
}

// ──────────────────────────────────────────────
// 09-01: AdminAction
// ──────────────────────────────────────────────

enum AdminActionType {
  suspend_account
  unsuspend_account
  suspend_gig
  unpublish_gig
  restore_gig
  restrict_project
  restore_project
  hold_payout
  release_payout
}

enum AdminTargetType {
  user
  project
  gig
  payout
}

model AdminAction {
  id           String          @id @default(cuid())
  actorId      String
  actionType   AdminActionType
  targetType   AdminTargetType
  targetId     String
  reasonCode   String?
  internalNote String?
  createdAt    DateTime        @default(now())

  actor User @relation(fields: [actorId], references: [id])

  @@index([targetType, targetId])
  @@index([actorId])
  @@index([createdAt])
}

// ──────────────────────────────────────────────
// 10-01: Gig (Stream 2 — Marketplace)
// ──────────────────────────────────────────────

enum GigStatus {
  draft
  published
  hired
  closed
  cancelled
  suspended
}

enum ApplicationStatus {
  submitted
  withdrawn
  accepted
  rejected
  expired
}

enum HireStatus {
  awaiting_start
  in_progress
  delivered
  approved
  cancelled
}

model Gig {
  id             String    @id @default(cuid())
  projectId      String
  creatorId      String
  title          String
  description    String
  skills         String[]
  genres         String[]
  budgetMin      Int?
  budgetMax      Int?
  budgetCurrency String    @default("USD")
  deadline       DateTime?
  status         GigStatus @default(draft)
  publishedAt    DateTime?
  closedAt       DateTime?
  cancelledAt    DateTime?
  suspendedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator      User             @relation(fields: [creatorId], references: [id])
  applications GigApplication[]
  hire         Hire?

  @@index([projectId])
  @@index([creatorId])
  @@index([status, publishedAt])
}

// ──────────────────────────────────────────────
// 11-01: GigApplication (Stream 2 — Hiring)
// ──────────────────────────────────────────────

model GigApplication {
  id          String            @id @default(cuid())
  gigId       String
  applicantId String
  coverNote   String
  proposedFee Int?
  status      ApplicationStatus @default(submitted)
  submittedAt DateTime          @default(now())
  decidedAt   DateTime?
  withdrawnAt DateTime?
  expiredAt   DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  gig       Gig   @relation(fields: [gigId], references: [id], onDelete: Cascade)
  applicant User  @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  hire      Hire?

  @@unique([gigId, applicantId])
  @@index([gigId, status])
  @@index([applicantId, status])
}

// ──────────────────────────────────────────────
// 11-02: Hire (delivery contract)
// ──────────────────────────────────────────────

model Hire {
  id            String     @id @default(cuid())
  gigId         String     @unique
  applicationId String     @unique
  buyerId       String
  talentId      String
  agreedFee     Int?
  feeCurrency   String     @default("USD")
  status        HireStatus @default(awaiting_start)
  startedAt     DateTime?
  deliveredAt   DateTime?
  approvedAt    DateTime?
  cancelledAt   DateTime?
  deliveryNote  String?
  cancelReason  String?
  memberRole    MemberRole @default(commenter)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  gig         Gig            @relation(fields: [gigId], references: [id], onDelete: Cascade)
  application GigApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  buyer       User           @relation("HireBuyer", fields: [buyerId], references: [id])
  talent      User           @relation("HireTalent", fields: [talentId], references: [id])
  payment     PaymentRecord?

  @@index([buyerId, status])
  @@index([talentId, status])
}

// ──────────────────────────────────────────────
// 12-01: ConnectAccount (Stripe Connect onboarding for talent payouts)
// ──────────────────────────────────────────────

enum ConnectStatus {
  not_started
  onboarding
  pending_verification
  verified
  restricted
  disabled
}

model ConnectAccount {
  id               String        @id @default(cuid())
  userId           String        @unique
  stripeAccountId  String?       @unique
  status           ConnectStatus @default(not_started)
  payoutsEnabled   Boolean       @default(false)
  chargesEnabled   Boolean       @default(false)
  detailsSubmitted Boolean       @default(false)
  country          String?
  defaultCurrency  String?
  requirementsDue  String[]      @default([])
  disabledReason   String?
  lastSyncedAt     DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

// ──────────────────────────────────────────────
// 12-02: PaymentRecord (buyer pays for hire — 1:1 with Hire)
// ──────────────────────────────────────────────

enum PaymentStatus {
  requires_payment
  processing
  succeeded
  failed
  refunded
  cancelled
}

model PaymentRecord {
  id                     String        @id @default(cuid())
  hireId                 String        @unique
  buyerId                String
  talentId               String
  amount                 Int
  currency               String        @default("USD")
  platformFee            Int           @default(0)
  status                 PaymentStatus @default(requires_payment)
  stripeCheckoutSessionId String?      @unique
  stripePaymentIntentId  String?       @unique
  stripeChargeId         String?
  failureCode            String?
  failureMessage         String?
  paidAt                 DateTime?
  refundedAt             DateTime?
  cancelledAt            DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  hire   Hire           @relation(fields: [hireId], references: [id], onDelete: Cascade)
  buyer  User           @relation("PaymentBuyer", fields: [buyerId], references: [id])
  talent User           @relation("PaymentTalent", fields: [talentId], references: [id])
  payout PayoutRecord?
  events PaymentEvent[]

  @@index([buyerId, status])
  @@index([talentId, status])
  @@index([status])
}

// ──────────────────────────────────────────────
// 12-03: PayoutRecord (platform → talent — 1:1 with PaymentRecord)
// ──────────────────────────────────────────────

enum PayoutStatus {
  blocked
  scheduled
  in_transit
  paid
  failed
  reversed
}

enum PayoutBlockReason {
  connect_onboarding_incomplete
  kyc_pending
  awaiting_buyer_approval
  admin_hold
}

model PayoutRecord {
  id                String             @id @default(cuid())
  paymentId         String             @unique
  talentId          String
  amount            Int
  currency          String             @default("USD")
  status            PayoutStatus       @default(blocked)
  blockReason       PayoutBlockReason?
  stripeTransferId  String?            @unique
  scheduledFor      DateTime?
  autoReleaseAt     DateTime?
  releasedAt        DateTime?
  paidAt            DateTime?
  failedAt          DateTime?
  failureCode       String?
  failureMessage    String?
  heldAt            DateTime?
  heldByActorId     String?
  reversedAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  payment PaymentRecord @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  talent  User          @relation("PayoutTalent", fields: [talentId], references: [id])

  @@index([talentId, status])
  @@index([status, autoReleaseAt])
  @@index([status, scheduledFor])
}
