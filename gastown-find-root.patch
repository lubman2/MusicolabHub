+// FindWithEnvOverride resolves the canonical town root for a working directory.
+// If GT_TOWN_ROOT or GT_ROOT is set to a valid workspace, it takes precedence
+// over a nested workspace discovered from cwd so commands run from rig/crew
+// directories still target the town-level socket and registry.
+func FindWithEnvOverride(startDir string) (string, error) {
+	for _, envName := range []string{"GT_TOWN_ROOT", "GT_ROOT"} {
+		if envRoot := os.Getenv(envName); envRoot != "" {
+			if root, ok := canonicalizeEnvWorkspace(envRoot); ok {
+				return root, nil
+			}
+		}
+	}
+	return Find(startDir)
+}
+
+func canonicalizeEnvWorkspace(envRoot string) (string, bool) {
+	if _, statErr := os.Stat(filepath.Join(envRoot, PrimaryMarker)); statErr == nil {
+		return envRoot, true
+	}
+
+	if info, statErr := os.Stat(filepath.Join(envRoot, SecondaryMarker)); statErr == nil && info.IsDir() {
+		if root, err := Find(envRoot); err == nil && root != "" {
+			return root, true
+		}
+		return envRoot, true
+	}
+
+	return "", false
+}
