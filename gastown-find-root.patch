+func TestFindFromCwdOrErrorPrefersEnvTownRootOverNestedCwd(t *testing.T) {
+	origCwd, err := os.Getwd()
+	if err != nil {
+		t.Fatalf("Getwd: %v", err)
+	}
+	defer func() {
+		_ = os.Chdir(origCwd)
+	}()
+
+	origTownRoot := os.Getenv("GT_TOWN_ROOT")
+	origRoot := os.Getenv("GT_ROOT")
+	defer func() {
+		_ = os.Setenv("GT_TOWN_ROOT", origTownRoot)
+		_ = os.Setenv("GT_ROOT", origRoot)
+	}()
+
+	townRoot := t.TempDir()
+	if err := os.MkdirAll(filepath.Join(townRoot, "mayor"), 0755); err != nil {
+		t.Fatalf("mkdir town mayor: %v", err)
+	}
+	if err := os.WriteFile(filepath.Join(townRoot, "mayor", "town.json"), []byte(`{"name":"outer"}`), 0644); err != nil {
+		t.Fatalf("write town.json: %v", err)
+	}
+
+	rigRoot := filepath.Join(townRoot, "MusicolabHub")
+	if err := os.MkdirAll(filepath.Join(rigRoot, "mayor"), 0755); err != nil {
+		t.Fatalf("mkdir rig mayor: %v", err)
+	}
+	if err := os.WriteFile(filepath.Join(rigRoot, "mayor", "town.json"), []byte(`{"name":"inner"}`), 0644); err != nil {
+		t.Fatalf("write rig town.json: %v", err)
+	}
+
+	nestedCwd := filepath.Join(rigRoot, "crew", "lubman")
+	if err := os.MkdirAll(nestedCwd, 0755); err != nil {
+		t.Fatalf("mkdir nested cwd: %v", err)
+	}
+
+	if err := os.Chdir(nestedCwd); err != nil {
+		t.Fatalf("Chdir: %v", err)
+	}
+
+	_ = os.Setenv("GT_TOWN_ROOT", "")
+	_ = os.Setenv("GT_ROOT", rigRoot)
+
+	found, err := FindFromCwdOrError()
+	if err != nil {
+		t.Fatalf("FindFromCwdOrError: %v", err)
+	}
+
+	if found != townRoot {
+		t.Fatalf("FindFromCwdOrError = %q, want %q", found, townRoot)
+	}
+}
