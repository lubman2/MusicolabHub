# =============================================================================
# MusicCollabHub — environment contract
# =============================================================================
# Copy to `.env` (local dev) or import into Vercel project env (prod/preview).
#   cp .env.example .env
# Production setup walkthrough: ./DEPLOYMENT.md
# =============================================================================

# ── Database (Postgres) ─────────────────────────────────────────────────────
# Local: docker postgres or Postgres.app.
# Production: Neon (https://neon.tech) — use the *pooled* connection string for
# DATABASE_URL on Vercel (serverless functions exhaust direct connections).
# For `prisma migrate deploy` use the *direct* connection string locally.
DATABASE_URL="postgresql://user:password@localhost:5432/musiccollabhub?schema=public"

# ── Auth (NextAuth / JWT) ───────────────────────────────────────────────────
# Generate: `openssl rand -base64 32`. Rotate by re-issuing in Vercel and
# redeploying — all sessions invalidate.
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ── App URLs ────────────────────────────────────────────────────────────────
# APP_URL is used server-side (emails, Stripe redirects, webhook callbacks).
# NEXT_PUBLIC_APP_URL is exposed to the browser bundle.
# On Vercel set both to the canonical public URL (https://yourdomain.com or
# the preview URL for non-prod environments).
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Object storage (AWS S3) ─────────────────────────────────────────────────
# Bucket must allow CORS PUT/GET from APP_URL (presigned uploads/downloads).
# Vercel runtime authenticates via the standard AWS SDK credential chain —
# set AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY as Vercel env vars; the SDK
# picks them up automatically (no code change needed).
# Use a dedicated IAM user with least-privilege on this bucket only.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="musiccollabhub-files"
AWS_REGION="eu-central-1"

# ── Stripe (payments + Connect) ─────────────────────────────────────────────
# Test mode keys for dev/preview, live keys for production.
# WEBHOOK_SECRET is per-endpoint — register https://<APP_URL>/api/webhooks/stripe
# in the Stripe dashboard, copy the signing secret into this var.
# PRICE IDs: create products in Stripe → Products → copy the price id.
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_TEAM_PRICE_ID="price_..."

# Marketplace platform fee in basis points (1500 = 15 %). Used by Stripe
# Connect destination charges. Default in code is 1500 if unset.
PLATFORM_FEE_BPS="1500"

# ── Email (SMTP) ────────────────────────────────────────────────────────────
# Dev: Mailtrap sandbox (https://mailtrap.io) — free, captures all outbound.
# Prod: Resend, Postmark, AWS SES, or SendGrid. Sender domain MUST be
# DKIM/SPF-verified or transactional mail goes to spam.
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@musiccollabhub.com"

# ── Cron (Vercel scheduled functions) ───────────────────────────────────────
# When set, /api/cron/* routes accept `Authorization: Bearer $CRON_SECRET`.
# Vercel injects this header automatically on scheduled invocations.
# Generate: `openssl rand -hex 32`.
CRON_SECRET=""

# ── E2E test harness ────────────────────────────────────────────────────────
# Set to "1" only in ephemeral test environments. Bypasses certain auth
# guards — NEVER set in production or on a publicly-reachable preview.
E2E_TEST_MODE=""
